#!/usr/bin/env zsh
session="dev"

# すでに dev セッションがあれば、それに入るだけ
if tmux has-session -t "$session" 2>/dev/null; then
  if [ -n "$TMUX" ]; then tmux switch-client -t "$session"; else tmux attach -t "$session"; fi
  exit 0
fi

# --- ウィンドウ1: 開発用レイアウト (メイン nvim + サイド2つ) ---
tmux new-session -d -s "$session" -n editor
tmux split-window -h -l 30% -t "$session:1"
tmux split-window -v         -t "$session:1"
tmux select-pane -L          -t "$session:1"
tmux send-keys   -t "$session:1" 'nvim' Enter

# --- ウィンドウ2: Claude用 4分割グリッド ---
tmux new-window  -t "$session" -n claude
tmux split-window -t "$session:2"
tmux split-window -t "$session:2"
tmux split-window -t "$session:2"
tmux select-layout -t "$session:2" tiled
# 左上ペインで claude を起動したい場合は次の2行を有効化
# tmux select-pane -t "$session:2.0"
# tmux send-keys   -t "$session:2.0" 'claude' Enter

# ウィンドウ1に戻してアタッチ
tmux select-window -t "$session:1"
if [ -n "$TMUX" ]; then tmux switch-client -t "$session"; else tmux attach -t "$session"; fi
